守护模式通过 time.Ticker 定时发送心跳
3. GitHub Actions 编译
文件：.github/workflows/build.yml
支持 13 种架构交叉编译（linux/darwin/windows/freebsd × amd64/arm64/386/arm/mips 等）
使用 CGO_ENABLED=0 纯 Go 静态编译，不依赖任何 C 库
使用 -ldflags="-s -w" 去除调试符号，减小体积
4. 编译排错
遇到 undefined: json 错误：在 api/heartbeat.go 的 import 中添加 "encoding/json"
遇到心跳不更新时间戳：将 GET 请求改为 PATCH 请求（GET 是只读操作，PATCH 才会更新服务器端时间戳）
四、最终 init.d 脚本架构
进程结构（5 个 procd 实例）
实例	命令	作用
usque_socks5	usque socks	SOCKS5 代理，供 Passwall 调用
usque_tun	usque nativetun	TUN 隧道，用于内网 Mesh
usque_hb_socks5	usque heartbeat --interval 5m	心跳守护（socks5 配置）
usque_hb_tun	usque heartbeat --interval 5m	心跳守护（nativetun 配置）
usque_watchdog	watchdog.sh	IPv6 变化监控
关键设计决策
心跳与隧道解耦：心跳只发 GET/PATCH 请求，不杀进程、不重写配置，隧道持续运行不受干扰
Watchdog 回归纯 IPv6 监控：不再定时 enroll，只在 IPv6 变化时执行 enroll 刷新配置
RAM Disk 保护闪存：所有动态脚本生成在 /var/run/usque/（内存盘），重启即焚
procd respawn 机制：进程崩溃后自动重启，Watchdog 不调用 init.d restart 避免死锁
心跳间隔 5 分钟：平衡 API 限流风险和后台时间新鲜度
init.d 脚本完整代码
#!/bin/sh /etc/rc.common

# =========================================================================
# 模块名称: usque (Cloudflare WARP/ZeroTrust 隧道 MASQUE协议)
# 适用场景: OpenWrt 生产环境 (旁路网关/主路由)，完美兼容 Passwall
# =========================================================================

START=95
STOP=10
USE_PROCD=1

# ========== [配置区：请根据实际网络环境修改] ==========
WAN_IF="br-lan"
SOCKS5_PORT="10800"
SOCKS5_BIND="127.0.0.1"
# SOCKS5_USER=""
# SOCKS5_PASS=""

ZT_SNI="zt-masque.cloudflareclient.com"
CONFIG_DIR="/etc/usque"
BIN="/usr/bin/usque"

RUN_DIR="/var/run/usque"
ROUTE_SCRIPT="${RUN_DIR}/on-connect.sh"
DISCONNECT_SCRIPT="${RUN_DIR}/on-disconnect.sh"
WATCHDOG_SCRIPT="${RUN_DIR}/watchdog.sh"

HEARTBEAT_INTERVAL="5m"

# ========== [首次注册教程 (SSH 中执行)] ==========
# 1. mkdir -p /etc/usque
# 2. 浏览器登录 https://<团队域名>.cloudflareaccess.com/warp
# 3. 在成功页面按 F12 打开控制台输入：
#    console.log(document.querySelector("meta[http-equiv='refresh']").content.split("=")[2])
# 4. 用 WinSCP 将 JWT 上传到 /tmp/jwt.txt (避免 SSH 粘贴换行问题)
# 5. 注册并生成配置文件：
#    JWT=$(cat /tmp/jwt.txt | tr -d '\n')
#    echo "y" | usque register -c /etc/usque/socks5.json --accept-tos --jwt "$JWT" --name Rbox-socks
#    echo "y" | usque register -c /etc/usque/nativetun.json --accept-tos --jwt "$JWT" --name Rbox-nativetun
#    rm -f /tmp/jwt.txt
# ==================================================

# =========================================================================
# DNS 防污染
# =========================================================================
setup_dns_bypass() {
    sed -i '/zt-masque.cloudflareclient.com/d' /etc/hosts
    echo "162.159.198.2 zt-masque.cloudflareclient.com #usque-bypass" >> /etc/hosts
    [ -x /etc/init.d/dnsmasq ] && /etc/init.d/dnsmasq reload 2>/dev/null
    [ -x /etc/init.d/smartdns ] && /etc/init.d/smartdns reload 2>/dev/null
}

cleanup_dns_bypass() {
    sed -i '/usque-bypass/d' /etc/hosts
    [ -x /etc/init.d/dnsmasq ] && /etc/init.d/dnsmasq reload 2>/dev/null
    [ -x /etc/init.d/smartdns ] && /etc/init.d/smartdns reload 2>/dev/null
}

# =========================================================================
# 动态生成辅助脚本 (储存于 RAM 中)
# =========================================================================
generate_scripts() {
    mkdir -p "$RUN_DIR"

    cat > "$ROUTE_SCRIPT" << 'EOF'
#!/bin/sh
nft insert rule inet fw4 forward iifname "usque0" accept 2>/dev/null
nft insert rule inet fw4 forward oifname "usque0" accept 2>/dev/null
nft insert rule inet fw4 input iifname "usque0" accept 2>/dev/null
# 如需组网(Site-to-Site)，在此处添加远端内网路由，例如：
# ip route add 192.168.88.0/24 dev usque0
EOF
    chmod +x "$ROUTE_SCRIPT"

    cat > "$DISCONNECT_SCRIPT" << 'EOF'
#!/bin/sh
nft delete rule inet fw4 forward iifname "usque0" accept 2>/dev/null
nft delete rule inet fw4 forward oifname "usque0" accept 2>/dev/null
nft delete rule inet fw4 input iifname "usque0" accept 2>/dev/null
# ip route del 192.168.88.0/24 dev usque0 2>/dev/null
EOF
    chmod +x "$DISCONNECT_SCRIPT"

    cat > "$WATCHDOG_SCRIPT" << EOF
#!/bin/sh
LAST_IPV6=""
while true; do
    sleep 60
    CUR_IPV6=\$(ip -6 addr show "$WAN_IF" scope global -deprecated 2>/dev/null | grep 'inet6' | awk '{print \$2}' | sort | tr '\n' ' ')
    [ -z "\$LAST_IPV6" ] && LAST_IPV6="\$CUR_IPV6"
    if [ "\$CUR_IPV6" != "\$LAST_IPV6" ] && [ -n "\$CUR_IPV6" ]; then
        logger -t usque-watchdog "检测到 $WAN_IF 的 IPv6 发生变化，执行 enroll..."
        "$BIN" enroll -c "${CONFIG_DIR}/nativetun.json" 2>/dev/null
        "$BIN" enroll -c "${CONFIG_DIR}/socks5.json" 2>/dev/null
        LAST_IPV6="\$CUR_IPV6"
        logger -t usque-watchdog "enroll 完成，杀死进程由 procd 拉起..."
        killall usque 2>/dev/null
    fi
done
EOF
    chmod +x "$WATCHDOG_SCRIPT"
}

# =========================================================================
# 启动/停止逻辑
# =========================================================================
start_service() {
    if [ ! -f "${CONFIG_DIR}/socks5.json" ] || [ ! -f "${CONFIG_DIR}/nativetun.json" ]; then
        logger -t usque "错误: 配置文件缺失，请先执行 usque register 命令"
        return 1
    fi

    setup_dns_bypass
    generate_scripts

    procd_open_instance "usque_socks5"
    procd_set_param command "$BIN" socks -s "$ZT_SNI" -b "$SOCKS5_BIND" -p "$SOCKS5_PORT" -c "${CONFIG_DIR}/socks5.json"
    procd_set_param respawn 3600 5 10
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance

    procd_open_instance "usque_tun"
    procd_set_param command "$BIN" nativetun -s "$ZT_SNI" -n usque0 -c "${CONFIG_DIR}/nativetun.json" --on-connect "$ROUTE_SCRIPT" --on-disconnect "$DISCONNECT_SCRIPT"
    procd_set_param respawn 3600 5 10
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance

    procd_open_instance "usque_hb_socks5"
    procd_set_param command "$BIN" heartbeat -c "${CONFIG_DIR}/socks5.json" --interval "$HEARTBEAT_INTERVAL"
    procd_set_param respawn 3600 5 0
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance

    procd_open_instance "usque_hb_tun"
    procd_set_param command "$BIN" heartbeat -c "${CONFIG_DIR}/nativetun.json" --interval "$HEARTBEAT_INTERVAL"
    procd_set_param respawn 3600 5 0
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance

    procd_open_instance "usque_watchdog"
    procd_set_param command "$WATCHDOG_SCRIPT"
    procd_set_param respawn 3600 5 0
    procd_close_instance

    logger -t usque "服务启动完成，SOCKS5: $SOCKS5_BIND:$SOCKS5_PORT，TUN: usque0，心跳: $HEARTBEAT_INTERVAL"
}

stop_service() {
    cleanup_dns_bypass
    rm -rf "$RUN_DIR"
    logger -t usque "服务已停止"
}

service_triggers() {
    procd_add_reload_trigger "usque"
}
